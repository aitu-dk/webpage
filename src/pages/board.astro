---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Board" description="Current and past boards of AITU">
  <main>
    <div class="max-w-4xl mt-10">
      <a href="/" class="text-sm text-accent">Back</a>
      <h1 class="my-6 text-3xl font-medium sm:text-4xl">Group Board Members</h1>
      <p class="text-lg font-light text-secondary my-2">
        Meet the current and previous boards of AITU. Photos and names will be updated soon.
      </p>

      <section class="my-8">
        <h2 class="text-2xl font-medium mb-2">Spring 2026 Board</h2>
        <div class="w-full h-40 bg-background-secondary flex items-center justify-center mb-4 rounded">
          <img src="/authors/group-photo-spring-2026.jpeg" alt="Spring 2026 Board" class="object-cover w-full h-full rounded" />
        </div>
        <ul class="grid grid-cols-2 sm:grid-cols-3 gap-4">
          <li class="flex flex-col items-center">
            <img src="/authors/johan-schmidt.jpeg" alt="Johan Schmidt" class="w-20 h-20 rounded-full object-cover mb-2" />
            <span class="text-secondary font-semibold">Johan Schmidt <span class="text-xs font-normal text-accent">(Chairman)</span></span>
          </li>
          <li class="flex flex-col items-center">
            <img src="/authors/vladimir-salnikov.jpeg" alt="Vladimir Salnikov" class="w-20 h-20 rounded-full object-cover mb-2" />
            <span class="text-secondary">Vladimir Salnikov</span>
          </li>
          <li class="flex flex-col items-center">
            <img src="/authors/pietro-rebecchi.jpeg" alt="Pietro Rebecchi" class="w-20 h-20 rounded-full object-cover mb-2" />
            <span class="text-secondary">Pietro Rebecchi</span>
          </li>
          <li class="flex flex-col items-center">
            <img src="/authors/dara-georgieva.jpeg" alt="Dara Georgieva" class="w-20 h-20 rounded-full object-cover mb-2" />
            <span class="text-secondary">Dara Georgieva</span>
          </li>
          <li class="flex flex-col items-center">
            <img src="/authors/maciej-jalocha.jpeg" alt="Maciej Jalocha" class="w-20 h-20 rounded-full object-cover mb-2" />
            <span class="text-secondary">Maciej Jalocha</span>
          </li>
        </ul>
      </section>

      <section class="my-8">
